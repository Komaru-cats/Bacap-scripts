# Checks if every type of jockey is close enough to you
execute if entity @e[type=chicken,predicate=blazeandcave:jockeys/chicken,distance=..16] if entity @e[type=camel_husk,predicate=blazeandcave:jockeys/camel_husk,distance=..16] if entity @e[type=hoglin,predicate=blazeandcave:jockeys/hoglin,distance=..16] if entity @e[type=ravager,predicate=blazeandcave:jockeys/ravager,distance=..16] if entity @e[type=skeleton_horse,predicate=blazeandcave:jockeys/skeleton_horse,distance=..16] if entity @e[type=spider,predicate=blazeandcave:jockeys/spider,distance=..16] if entity @e[type=zombie_horse,predicate=blazeandcave:jockeys/zombie_horse,distance=..16] if entity @e[type=zombie_nautilus,predicate=blazeandcave:jockeys/zombie_nautilus,distance=..16] run advancement grant @s only blazeandcave:monsters/jockey_jamboree
